# ── Supabase (nuvem) ─────────────────────────────────────────────────────────
# Opcional. Sem estas variáveis o app persiste em localStorage.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SmartTank Bridge (medidor TLS-450 PLUS) ─────────────────────────────────
# Serviço local (Docker) que lê o Veeder-Root e expõe REST + WebSocket na LAN
# do posto. Sem estas variáveis o Dashboard roda em MODO DEMONSTRAÇÃO (mock).
#
# ⚠️ SEGURANÇA: o token fica visível no client. Isto só é aceitável porque o
# app é servido/acessado dentro da rede local do posto e o bridge não é
# exposto à internet. Se um dia houver backend próprio ou acesso externo,
# faça um proxy server-side que injeta o x-api-key e nunca exponha o token.
VITE_BRIDGE_URL=http://192.168.20.83:3050
VITE_BRIDGE_TOKEN=
