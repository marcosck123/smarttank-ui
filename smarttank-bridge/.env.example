# ===== Transporte com o TLS-450 =====
# "tcp" ou "serial" — decida depois de verificar no posto
TLS_TRANSPORT=tcp

# --- Se TCP ---
TLS_HOST=192.168.0.50
TLS_PORT=10001

# --- Se serial (RS-232) ---
TLS_SERIAL_PATH=COM3
TLS_BAUD_RATE=9600
# data bits / paridade / stop bits padrão Veeder-Root: 8 N 1
# Confirme no console: Menu > Setup > Communications

# ===== Polling =====
# Intervalo entre leituras do equipamento (ms). Não desça de 10000.
POLL_INTERVAL_MS=20000
# Timeout de resposta de um comando (ms)
COMMAND_TIMEOUT_MS=8000

# ===== API do bridge =====
API_PORT=3050
# Token exigido no header "x-api-key" (gere um: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))")
BRIDGE_TOKEN=troque-este-token
# Origens permitidas no CORS, separadas por vírgula ("*" libera tudo — evite)
CORS_ORIGINS=http://localhost:3000
